{
  "name": "@carlossts/react-native-leaflet-platform",
  "version": "1.0.4",
  "publishConfig": {
    "access": "public"
  },
  "description": "A React Native library for interactive maps using Leaflet, compatible with Android, iOS, Web, and Expo.",
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "lib/",
    "src/",
    "android/",
    "ios/",
    "react-native-leaflet-platform.podspec",
    "scripts/"
  ],
  "keywords": [
    "react-native",
    "leaflet",
    "map",
    "expo",
    "react-native-web",
    "webview"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/carlossts/react-native-leaflet-platform"
  },
  "author": "Carlos Ferreira",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "yarn build",
    "copy-leaflet-html-web": "sh scripts/copy-leaflet-html.sh",
    "patch-webview-ios": "sh scripts/patch-react-native-webview-ios.sh"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-webview": ">=13.0.0",
    "react-native-web": ">=0.19.0"
  },
  "peerDependenciesMeta": {
    "react-native-webview": {
      "optional": true
    },
    "react-native-web": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "19.2.0",
    "react": "19.2.4",
    "react-native": "0.84.1",
    "react-native-web": "0.21.2",
    "react-native-webview": "13.16.1",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}